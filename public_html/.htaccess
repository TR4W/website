Options +Indexes

# ── Download redirect ───────────────────────────────────────────────
# Stable URLs for the current major release. The download buttons in
# index.html link to /download/tr4w_setup[_<lang>].exe and never change;
# only the target version below is bumped each release (bin/release.sh).
# 302 = temporary, so caches/proxies don't pin an old version.
RewriteEngine On
RewriteRule ^download/tr4w_setup(_[a-z]{3})?\.exe$ https://tr4w.net/4.148/tr4w_setup_4.148.3$1.exe [R=302,L]
